# Canlı AI Asistan — OpenRouter anahtarı.
# Bu dosyayı .env olarak kopyala ve doldur. Anahtar SADECE bu sunucuda kalır, tarayıcıya gitmez.
#
# Anahtarı nasıl alırsın:
#   1) https://openrouter.ai adresine gir, Google/GitHub ile giriş yap
#   2) https://openrouter.ai/keys → "Create Key"
#   3) Çıkan anahtarı (sk-or-... ile başlar) aşağıya yapıştır

OPENROUTER_API_KEY=

# Model: boş bırakırsan sunucu otomatik en güncel Opus modelini seçer.
# İstersen elle sabitle (örn. anthropic/claude-opus-4.8).
OPENROUTER_MODEL=

PORT=8080

# Teklif Toplama e-postası (Hostinger). Mailbox'ı hPanel > Emails'ten oluştur.
MAIL_USER=insaat@pokkop.com
MAIL_PASS=
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
