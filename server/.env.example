# Canlı AI Asistan — Anthropic (Claude) anahtarı.
# Bu dosyayı .env olarak kopyala ve doldur. Anahtar SADECE bu sunucuda kalır, tarayıcıya gitmez.
#
# Anahtarı nasıl alırsın:
#   1) https://console.anthropic.com adresine gir / kayıt ol
#   2) Sol menü → API Keys → "Create Key"
#   3) Çıkan anahtarı (sk-ant-... ile başlar) aşağıya yapıştır

ANTHROPIC_API_KEY=

# Model: boş bırakırsan sunucu otomatik en güncel Opus modelini seçer.
# İstersen elle sabitle (örn. claude-opus-4-1-20250805).
ANTHROPIC_MODEL=

PORT=8080
