# Autodesk APS (Forge) anahtarları — bu dosyayı .env olarak kopyalayıp doldur.
# Anahtarları https://aps.autodesk.com/ → "Create App" ile alırsın (kurulum rehberine bak).

APS_CLIENT_ID=buraya_client_id
APS_CLIENT_SECRET=buraya_client_secret

# Bölge: US veya EMEA (Avrupa). Varsayılan US.
APS_REGION=US

# Çizimlerin saklanacağı kova adı (küçük harf, harf/rakam/-). Boş bırakırsan otomatik üretilir.
APS_BUCKET=

# Sunucu portu
PORT=8080
